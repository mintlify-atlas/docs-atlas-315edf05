  "keyFeatures": [
    "Accurate Lemmings game engine supporting 25M+ simultaneous lemmings at 60x speed",
    "Full-featured level editor with undo/redo, import/export for .nxlv and .lvl formats",
    "WebMIDI sequencing with routing, input mapping, and real-time controls",
    "MCP server for AI automation with state inspection and vision capture",
    "Time travel with tick-by-tick stepping and reverse playback",
    "Interactive spectator mode for watching AI agents play",
    "Procedural level generation with AI director",
    "Browser-based PWA with offline support"
  ],
